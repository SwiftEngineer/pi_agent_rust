{
  "schema": "pi.swarm.work_admission_gate_contract.v1",
  "work_admission_gate_schema": "pi.swarm.work_admission_gate.v1",
  "purpose": "fail_closed_swarm_work_admission_gate_not_source_of_truth",
  "description": "Contract for the advisory swarm work-admission gate. The gate consumes captured Beads, git, RCH, validation, evidence freshness, Agent Mail, autopilot plan, and action-plan signals, then classifies whether implementation, coordination work, evidence renewal, waiting, or escalation is the safest next action.",
  "allowed_statuses": [
    "admit",
    "limited",
    "wait",
    "blocked"
  ],
  "allowed_decisions": [
    "proceed_with_implementation",
    "create_or_refine_bead",
    "renew_evidence",
    "wait",
    "pause_escalate"
  ],
  "required_top_level_keys": [
    "schema",
    "generated_at",
    "status",
    "purpose",
    "input_pack_schema",
    "source_plan_schema",
    "action_plan_schema",
    "decision",
    "source_signals",
    "failure_actions",
    "degraded_reasons",
    "forbidden_actions",
    "gate_guards",
    "redaction_summary"
  ],
  "required_decision_fields": [
    "decision",
    "status",
    "source_action_plan_decision",
    "source_action",
    "rank",
    "title",
    "severity",
    "confidence",
    "rationale",
    "blockers",
    "evidence_paths",
    "command_safety_classes",
    "admit_new_implementation",
    "admit_coordination_work",
    "commands_require_operator_execution"
  ],
  "required_source_signal_keys": [
    "beads",
    "agent_mail",
    "rch",
    "git",
    "validation_broker",
    "evidence"
  ],
  "required_true_guards": [
    "fail_closed",
    "dry_run_only",
    "no_source_mutation",
    "commands_require_operator_execution",
    "does_not_replace_beads_agent_mail_rch_validation_broker_doctor_or_ci"
  ],
  "required_forbidden_actions": [
    "destructive git reset",
    "destructive git clean",
    "recursive filesystem deletion",
    "file deletion",
    "automatic commit",
    "automatic file reservation"
  ],
  "fail_closed_policy": {
    "implementation_requires_no_blockers": true,
    "missing_required_evidence_blocks_implementation": true,
    "stale_required_evidence_routes_to_renewal": true,
    "active_validation_failure_blocks_implementation": true,
    "unavailable_ownership_signal_blocks_implementation": true,
    "rch_backoff_blocks_heavy_implementation": true,
    "dirty_worktree_blocks_new_implementation": true
  },
  "authority_boundary": {
    "does_not_replace": [
      "Beads",
      "Agent Mail",
      "git",
      "RCH",
      "validation broker",
      "doctor",
      "CI",
      "human operator judgment"
    ],
    "may_recommend_only": true,
    "must_not_execute_commands": true,
    "must_refuse_source_mutation": true
  },
  "required_replay_scenarios": [
    "healthy_ready_claim",
    "empty_ready_queue",
    "deferred_roadmap_backlog",
    "degraded_agent_mail_soft_lock",
    "saturated_rch_queue",
    "unrelated_dirty_worktree",
    "stale_action_plan_evidence",
    "validation_failure_fail_closed",
    "malformed_source_fail_closed"
  ]
}
