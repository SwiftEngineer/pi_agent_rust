{
  "schema": "pi.operator.handoff_summary_contract.v1",
  "input_schema": "pi.operator.handoff_summary_input.v1",
  "output_schema": "pi.operator.handoff_summary.v1",
  "purpose": "read_only_operator_handoff_invariant_summary",
  "description": "Contract for deterministic operator handoff summaries that combine Beads, git refs, validation status, evidence freshness, Agent Mail health/reservations, RCH status, and open action-plan decisions into JSON plus Markdown.",
  "allowed_statuses": [
    "clean",
    "watch",
    "blocked"
  ],
  "required_top_level_keys": [
    "schema",
    "generated_at",
    "status",
    "purpose",
    "project",
    "git",
    "beads",
    "source_statuses",
    "invariants",
    "safe_next_actions",
    "must_not_touch",
    "gates_proving_claim",
    "open_action_plan_decisions",
    "redaction_summary",
    "guardrails",
    "markdown"
  ],
  "required_invariants": [
    "git_worktree_clean",
    "git_pushed",
    "validation_gates",
    "evidence_freshness",
    "agent_mail_usable",
    "reservations_current",
    "rch_available",
    "action_plan_decisions"
  ],
  "required_true_guardrails": [
    "read_only_summary",
    "no_source_mutation",
    "no_git_mutation",
    "no_beads_mutation",
    "no_agent_mail_mutation",
    "output_overwrite_refusal"
  ],
  "required_fixture_scenarios": [
    "clean_handoff",
    "dirty_worktree",
    "unpushed_commits",
    "expired_reservations",
    "stale_evidence",
    "failed_validation",
    "redaction"
  ],
  "authority_boundary": {
    "does_not_replace": [
      "Beads",
      "Agent Mail",
      "git",
      "RCH",
      "validation broker",
      "CI",
      "operator judgment"
    ],
    "may_recommend_only": true,
    "must_not_execute_commands": true,
    "must_refuse_output_overwrite": true
  }
}
