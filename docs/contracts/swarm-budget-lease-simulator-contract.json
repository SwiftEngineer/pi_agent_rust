{
  "schema": "pi.swarm.budget_lease_simulator_contract.v1",
  "simulation_schema": "pi.swarm.budget_lease_simulation.v1",
  "request_schema": "pi.swarm.budget_lease_request.v1",
  "purpose": "dry_run_swarm_budget_lease_simulation_not_source_of_truth",
  "description": "Contract for deterministic pre-launch budget lease simulation across provider, tool, RCH, temp-dir, session, and evidence write lanes. The simulator recommends per-agent leases and conflicts only; it does not reserve capacity or enforce throttles.",
  "allowed_statuses": [
    "admit",
    "limited",
    "blocked"
  ],
  "allowed_decisions": [
    "grant",
    "partial",
    "reject"
  ],
  "resource_keys": [
    "provider_tokens",
    "provider_spend_microusd",
    "tool_invocations",
    "rch_slots",
    "temp_dir_bytes",
    "session_write_bytes",
    "evidence_write_bytes"
  ],
  "conflict_types": [
    "lease_trimmed",
    "over_commit_rejected",
    "rch_saturation",
    "provider_budget_exhausted"
  ],
  "required_top_level_keys": [
    "schema",
    "generated_at",
    "status",
    "purpose",
    "input_schema",
    "resource_keys",
    "summary",
    "resource_summaries",
    "recommendations",
    "conflicts",
    "active_leases",
    "expired_leases",
    "simulator_guards",
    "authority_boundary"
  ],
  "required_true_guards": [
    "dry_run_only",
    "no_runtime_throttles_enforced",
    "no_source_mutation",
    "output_overwrite_refusal",
    "deterministic_allocation"
  ],
  "required_fixture_scenarios": [
    "fair_allocation",
    "over_commit_rejection",
    "stale_lease_expiry",
    "mixed_priority_agents",
    "rch_saturation",
    "provider_budget_exhaustion"
  ],
  "authority_boundary": {
    "does_not_replace": [
      "Beads",
      "Agent Mail",
      "RCH",
      "provider billing limits",
      "filesystem quotas",
      "validation broker",
      "operator judgment"
    ],
    "may_recommend_only": true,
    "must_not_reserve_capacity": true,
    "must_not_enforce_runtime_throttles": true,
    "must_refuse_output_overwrite": true
  },
  "allocation_policy": {
    "priority_weight": {
      "P0": 5,
      "P1": 4,
      "P2": 3,
      "P3": 2,
      "P4": 1
    },
    "algorithm": "For each resource, active unexpired leases are subtracted from capacity; expired leases are ignored with evidence. If requested total fits, each request is granted. If minimum total exceeds available capacity, the resource is hard-conflict allocated proportionally by priority weight and request order. Otherwise minimums are reserved first and the remaining budget is distributed by weighted largest remainder with deterministic tie-breaks."
  }
}
